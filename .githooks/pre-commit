#!/usr/bin/env bash
# dotfiles-guard pre-commit: scan staged additions (content + filenames) before commit.
set -uo pipefail
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export GUARD_FILES="$(git diff --cached --name-only --diff-filter=ACM)"
git diff --cached -U0 --diff-filter=ACM | "$DIR/guard.sh" commit
